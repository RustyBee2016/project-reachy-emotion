{
  "name": "Agent 3 — Promotion/Curation Agent (Reachy 08.4.2)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "promotion/v1",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook_promotion",
      "name": "Webhook: request.promotion",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 3,
      "position": [-800, 300],
      "webhookId": "promotion-request"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Validate promotion request\nconst body = $json.body ?? $json;\nconst required = ['video_id', 'label'];\n\nfor (const field of required) {\n  if (!body[field]) {\n    throw new Error(`Missing required field: ${field}`);\n  }\n}\n\nconst allowedSplits = ['train', 'test'];\nconst target = body.target || body.dest_split || 'train';\n\nif (!allowedSplits.includes(target)) {\n  throw new Error(`Invalid target split: ${target}`);\n}\n\n// Generate stable idempotency key\nconst crypto = require('crypto');\nconst idem = body.idempotency_key || crypto.createHash('sha256')\n  .update(`${body.video_id}|${target}|${body.label}`)\n  .digest('hex').slice(0, 32);\n\nreturn [{\n  json: {\n    video_id: body.video_id,\n    label: body.label,\n    target,\n    idempotency_key: idem,\n    correlation_id: body.correlation_id || `promo-${Date.now()}`,\n    dry_run: true  // Start with dry-run\n  }\n}];"
      },
      "id": "validate_request",
      "name": "Code: validate.request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-600, 300]
    },
    {
      "parameters": {
        "url": "={{$env.MEDIA_MOVER_BASE_URL}}/api/promote",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Idempotency-Key",
              "value": "={{$json.idempotency_key}}"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "video_id",
              "value": "={{$json.video_id}}"
            },
            {
              "name": "dest_split",
              "value": "={{$json.target}}"
            },
            {
              "name": "label",
              "value": "={{$json.label}}"
            },
            {
              "name": "dry_run",
              "value": "=true"
            },
            {
              "name": "correlation_id",
              "value": "={{$json.correlation_id}}"
            }
          ]
        }
      },
      "id": "http_dryrun",
      "name": "HTTP: dryrun.promote",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [-400, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "1",
          "name": "Media Mover Auth"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Summarize dry-run plan for approval\nconst plan = $json;\n\nreturn [{\n  json: {\n    approval_request: {\n      title: 'Video Promotion Request',\n      video_id: $('validate_request').item.json.video_id,\n      label: $('validate_request').item.json.label,\n      target_split: $('validate_request').item.json.target,\n      plan_summary: {\n        will_move: plan.moves || [],\n        will_update_db: plan.will_update_db !== false,\n        conflicts: plan.conflicts || [],\n        dry_run_status: plan.status\n      },\n      correlation_id: $('validate_request').item.json.correlation_id,\n      idempotency_key: $('validate_request').item.json.idempotency_key\n    }\n  }\n}];"
      },
      "id": "summarize_plan",
      "name": "Code: summarize.plan",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-200, 300]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "promotion/approve",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "webhook_approval",
      "name": "Webhook: await.approval",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 3,
      "position": [0, 300],
      "webhookId": "promotion-approval"
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$json.approved}}",
              "value2": true
            }
          ]
        }
      },
      "id": "if_approved",
      "name": "IF: approved?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [200, 300]
    },
    {
      "parameters": {
        "url": "={{$env.MEDIA_MOVER_BASE_URL}}/api/promote",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Idempotency-Key",
              "value": "={{$json.idempotency_key}}"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "video_id",
              "value": "={{$json.video_id}}"
            },
            {
              "name": "dest_split",
              "value": "={{$json.target_split}}"
            },
            {
              "name": "label",
              "value": "={{$json.label}}"
            },
            {
              "name": "dry_run",
              "value": "=false"
            },
            {
              "name": "correlation_id",
              "value": "={{$json.correlation_id}}"
            }
          ]
        }
      },
      "id": "http_real_promote",
      "name": "HTTP: real.promote",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [400, 200],
      "credentials": {
        "httpHeaderAuth": {
          "id": "1",
          "name": "Media Mover Auth"
        }
      }
    },
    {
      "parameters": {
        "url": "={{$env.MEDIA_MOVER_BASE_URL}}/api/manifest/rebuild",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Correlation-ID",
              "value": "={{$json.correlation_id}}"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "splits",
              "value": "=[\"train\", \"test\"]"
            }
          ]
        }
      },
      "id": "http_rebuild_manifest",
      "name": "HTTP: rebuild.manifest",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [600, 200],
      "credentials": {
        "httpHeaderAuth": {
          "id": "1",
          "name": "Media Mover Auth"
        }
      }
    },
    {
      "parameters": {
        "url": "={{$env.GATEWAY_BASE_URL}}/api/events/promotion",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "event_type",
              "value": "=promotion.completed"
            },
            {
              "name": "video_id",
              "value": "={{$json.video_id}}"
            },
            {
              "name": "dest_split",
              "value": "={{$json.target_split}}"
            },
            {
              "name": "label",
              "value": "={{$json.label}}"
            },
            {
              "name": "correlation_id",
              "value": "={{$json.correlation_id}}"
            },
            {
              "name": "dataset_hash",
              "value": "={{$('http_rebuild_manifest').item.json.dataset_hash}}"
            }
          ]
        }
      },
      "id": "emit_completed",
      "name": "HTTP: emit.completed",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [800, 200]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ {\n  \"status\": \"success\",\n  \"video_id\": $json.video_id,\n  \"dest_split\": $json.target_split,\n  \"dataset_hash\": $json.dataset_hash,\n  \"correlation_id\": $json.correlation_id\n} }}"
      },
      "id": "respond_success",
      "name": "Respond: success",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1000, 200]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ {\n  \"status\": \"rejected\",\n  \"message\": \"Promotion not approved\",\n  \"correlation_id\": $json.correlation_id\n} }}",
        "options": {
          "responseCode": 403
        }
      },
      "id": "respond_rejected",
      "name": "Respond: rejected",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [400, 400]
    }
  ],

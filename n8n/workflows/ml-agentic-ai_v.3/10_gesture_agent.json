    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Normalize and validate the incoming gesture cue.\nconst body = $json.body ?? $json;\n\n// Emotion (3-class Phase 1 output)\nconst VALID_EMOTIONS = new Set(['happy','sad','neutral','anger','fear','disgust','contempt','surprise','unknown']);\nconst emotion = ((body.emotion ?? 'unknown')).toLowerCase();\nif (!VALID_EMOTIONS.has(emotion)) {\n  throw new Error(`Invalid emotion '${emotion}'. Allowed: ${[...VALID_EMOTIONS].join(', ')}`);\n}\n\nconst confidence = parseFloat(body.confidence ?? 0);\nif (isNaN(confidence) || confidence < 0 || confidence > 1) {\n  throw new Error(`Invalid confidence '${body.confidence}'. Must be 0.0–1.0.`);\n}\n\n// Ekman PPE class (may differ from 3-class emotion, set by PPE layer)\nconst ekman_class = ((body.ekman_class ?? emotion)).toLowerCase();\n\n// Gesture keywords (from LLM keyword parser or PPE layer)\nconst gesture_keywords = Array.isArray(body.gesture_keywords) ? body.gesture_keywords : [];\n\n// Simulation mode — bypass SSH, return mock response\nconst sim_mode = body.sim_mode === true || body.sim_mode === 'true' ||\n  $json.headers?.['x-sim-mode'] === 'true';\n\n// Response strategy from PPE layer (e.g. de_escalate, provide_support)\nconst response_strategy = body.response_strategy ?? 'engage_openly';\n\n// Correlation ID for distributed tracing\nconst incomingCorrelation = ($json.headers?.['x-correlation-id'] ?? '').trim();\nconst correlation_id = incomingCorrelation || `gest-${Date.now()}-${Math.random().toString(36).slice(2, 9)}`;\n\nreturn [{\n  json: {\n    emotion,\n    ekman_class,\n    confidence,\n    gesture_keywords,\n    sim_mode,\n    response_strategy,\n    correlation_id,\n    received_at: new Date().toISOString()\n  }\n}];"
      },
      "id": "code_parse_cue",
      "name": "Code: parse.cue",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-480, 300]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Map confidence → expressiveness tier and select the target gesture.\n// Mirrors gesture_modulator.py tier thresholds.\nconst {\n  emotion, ekman_class, confidence, gesture_keywords,\n  sim_mode, response_strategy, correlation_id, received_at\n} = $json;\n\nlet tier;\nif      (confidence < 0.60) tier = 1;  // Abstain — Minimal\nelse if (confidence < 0.70) tier = 2;  // Subtle\nelse if (confidence < 0.80) tier = 3;  // Moderate\nelse if (confidence < 0.90) tier = 4;  // Expressive\nelse                        tier = 5;  // Full\n\nconst TIER_CONFIG = {\n  1: { amplitude: 0.25, speed: 'none',   label: 'Minimal/Abstain' },\n  2: { amplitude: 0.50, speed: 'slow',   label: 'Subtle' },\n  3: { amplitude: 0.75, speed: 'normal', label: 'Moderate' },\n  4: { amplitude: 1.00, speed: 'normal', label: 'Expressive' },\n  5: { amplitude: 1.00, speed: 'fast',   label: 'Full' },\n};\n\n// Fallback gesture map (mirrors emotion_gesture_map.py primary gestures)\nconst FALLBACK_MAP = {\n  happy:    ['WAVE', 'CELEBRATE', 'EXCITED', 'THUMBS_UP'],\n  sad:      ['EMPATHY', 'COMFORT', 'HUG', 'SAD_ACK'],\n  neutral:  ['NOD', 'LISTEN', 'THINK', 'WAVE'],\n  anger:    ['LISTEN', 'NOD', 'NEUTRAL'],\n  fear:     ['COMFORT', 'HUG', 'LISTEN'],\n  disgust:  ['NOD', 'NEUTRAL', 'LISTEN'],\n  contempt: ['LISTEN', 'NOD'],\n  surprise: ['EXCITED', 'WAVE', 'CELEBRATE'],\n  unknown:  ['LISTEN', 'NOD'],\n};\n\n// Prefer caller-supplied keywords; fall back to emotion map\nconst candidates = gesture_keywords.length > 0\n  ? gesture_keywords\n  : (FALLBACK_MAP[ekman_class] ?? FALLBACK_MAP.unknown);\n\n// De-escalation policy: anger/contempt always cap at tier 2 even if conf is high\nconst DE_ESCALATE = new Set(['anger', 'contempt']);\nconst effective_tier = DE_ESCALATE.has(ekman_class) ? Math.min(tier, 2) : tier;\n\nconst cfg = TIER_CONFIG[effective_tier];\nconst selected_gesture = effective_tier === 1 ? 'NEUTRAL' : (candidates[0] ?? 'NEUTRAL');\n\nreturn [{\n  json: {\n    emotion,\n    ekman_class,\n    confidence,\n    tier: effective_tier,\n    tier_label: cfg.label,\n    selected_gesture,\n    amplitude: cfg.amplitude,\n    speed: cfg.speed,\n    abstain: effective_tier === 1,\n    de_escalated: DE_ESCALATE.has(ekman_class) && tier > 2,\n    sim_mode,\n    response_strategy,\n    correlation_id,\n    gesture_candidates: candidates,\n    received_at\n  }\n}];"
      },

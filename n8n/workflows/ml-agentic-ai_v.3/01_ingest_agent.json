{
  "name": "Agent 1 \u2014 Ingest Agent (Reachy 08.4.2 v3)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "video_gen_hook",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook_trigger",
      "name": "Webhook: ingest.video",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 3,
      "position": [
        -400,
        300
      ],
      "webhookId": "ingest-video-hook"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Normalize payload and enforce 3-class policy when label is provided.\nconst clean = (v) => (typeof v === 'string' ? v.trim() : '');\nconst body = $json.body ?? $json;\nconst sourceUrl = clean(body.source_url ?? body.url ?? body.asset?.url ?? body.data?.asset?.url);\n\nif (!sourceUrl) {\n  throw new Error('Missing source_url in request body');\n}\n\nconst allowedLabels = new Set(['happy', 'sad', 'neutral']);\nlet label = clean(body.label ?? body.emotion ?? '').toLowerCase();\nif (!label) {\n  label = null;\n}\nif (label && !allowedLabels.has(label)) {\n  throw new Error(`Invalid label '${label}'. Allowed: happy, sad, neutral`);\n}\n\nconst meta = body.meta ?? {};\nconst generator = clean(meta.generator ?? body.generator ?? body.source ?? 'unknown') || 'unknown';\nconst prompt = clean(meta.prompt ?? body.prompt ?? '');\nconst source = clean(meta.source ?? body.source ?? 'agent1.ingest_agent') || 'agent1.ingest_agent';\n\nconst incomingCorrelation = clean($json.headers?.['x-correlation-id']);\nconst correlationId = incomingCorrelation || `ing-${Date.now()}-${Math.random().toString(36).slice(2, 10)}`;\n\nconst incomingIdempotency = clean($json.headers?.['idempotency-key']);\nconst stableSeed = `${sourceUrl}|${label ?? ''}|${generator}|${prompt}`;\nlet hash = 0;\nfor (let i = 0; i < stableSeed.length; i += 1) {\n  hash = ((hash << 5) - hash) + stableSeed.charCodeAt(i);\n  hash |= 0;\n}\nconst stableIdempotency = `idem-${Math.abs(hash).toString(36)}`;\nconst idempotencyKey = incomingIdempotency || stableIdempotency;\n\nreturn [{\n  json: {\n    source_url: sourceUrl,\n    label,\n    meta: {\n      generator,\n      prompt,\n      source\n    },\n    correlation_id: correlationId,\n    idempotency_key: idempotencyKey,\n    issued_at: new Date().toISOString(),\n    schema_version: 'v1'\n  }\n}];"
      },
      "id": "normalize_payload",
      "name": "Code: normalize.payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -100,
        300
      ]
    },
    {
      "parameters": {
        "url": "http://10.0.4.130:8083/api/v1/ingest/pull",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Idempotency-Key",
              "value": "={{$json.idempotency_key}}"
            },
            {
              "name": "X-Correlation-ID",
              "value": "={{$json.correlation_id}}"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "source_url",
              "value": "={{$json.source_url}}"
            },
            {
              "name": "correlation_id",
              "value": "={{$json.correlation_id}}"
            },
            {
              "name": "intended_emotion",
              "value": "={{$json.label}}"
            },
            {
              "name": "generator",
              "value": "={{$json.meta.generator}}"
            },
            {
              "name": "prompt",
              "value": "={{$json.meta.prompt}}"
            }
          ]
        },
        "options": {
          "timeout": 120000
        },
        "method": "POST"
      },
      "id": "media_pull",
      "name": "HTTP: media.pull",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        200,
        300
      ],
      "retryOnFail": true,
      "maxTries": 5,
      "waitBetweenTries": 1000
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ ['done','duplicate'].includes($json.status) }}",
              "value2": true
            }
          ]
        },
        "options": {}
      },
      "id": "is_done",
      "name": "IF: status.done?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        500,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://10.0.4.140:8000/api/events/ingest",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "schema_version",
              "value": "={{$json.schema_version || 'v1'}}"
            },
            {
              "name": "event_type",
              "value": "={{$json.status === 'duplicate' ? 'ingest.duplicate' : 'ingest.completed'}}"
            },
            {
              "name": "source",
              "value": "={{$json.meta?.source || 'agent1.ingest_agent'}}"
            },
            {
              "name": "issued_at",
              "value": "={{$now.toISO()}}"
            },
            {
              "name": "video_id",
              "value": "={{$json.video_id}}"
            },
            {
              "name": "correlation_id",
              "value": "={{$json.correlation_id}}"
            },
            {
              "name": "file_path",
              "value": "={{$json.file_path}}"
            },
            {
              "name": "sha256",
              "value": "={{$json.sha256}}"
            },
            {
              "name": "duplicate",
              "value": "={{$json.duplicate || false}}"
            }
          ]
        },
        "options": {
          "timeout": 60000
        }
      },
      "id": "emit_event",
      "name": "HTTP: emit.completed",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        800,
        200
      ],
      "retryOnFail": true,
      "maxTries": 5,
      "waitBetweenTries": 1000
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ {\"status\": $json.status || 'accepted', \"video_id\": $json.video_id || null, \"correlation_id\": $json.correlation_id || null, \"duplicate\": $json.duplicate || false} }}",
        "options": {
          "responseCode": 200
        }
      },
      "id": "respond_success",
      "name": "Respond: success",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        1100,
        300
      ]
    }
  ],
  "connections": {
    "webhook_trigger": {
      "main": [
        [
          {

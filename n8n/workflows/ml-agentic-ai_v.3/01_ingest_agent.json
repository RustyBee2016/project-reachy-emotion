            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "media_pull": {
      "main": [
        [
          {
            "node": "is_done",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "is_done": {
      "main": [
        [
          {
            "node": "emit_event",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "respond_success",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "emit_event": {
      "main": [
        [
          {
            "node": "respond_success",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "pinData": {},

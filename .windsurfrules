memory_system_rules:
  primary_system: "memory-bank"
  project_name: "reachy_cloud_08.3"
  
initialization:
  trigger: "first_interaction"
  priority: "immediate"
  required: true
  actions:
    - "Before doing ANYTHING else, read and fully internalize ALL rules in this file."
    - "Check if memory-bank/ directory exists."
    - "If memory-bank exists: Read core files (index.md, requirements.md, AGENTS.md). Set status to [MEMORY BANK: ACTIVE]."
    - "If memory-bank does NOT exist: Inform user. Ask to create and provide yes and no response choices. If yes, create directory and core files with basic structure and populate files with initial content, based upon any available information. If no, set status to [MEMORY BANK: INACTIVE]."
    - "Load context from memory-bank files if active."
    - "Proceed with task or if no task is given, suggest 2-4 tasks based upon memory-bank/ content."

  validation:
    - "Verify memory-bank status (ACTIVE/INACTIVE)."
    - "If ACTIVE, confirm core files were read."

system_validation:
  startup:
    - "Verify .windsurfrules loaded"
    - "Check memory-bank accessibility if expected"
    - "Confirm initialization sequence complete"

memory_bank:
  core_files:
    index.md:
      purpose: "Curated entry points to project context, decisions, and references"
      location: "memory-bank/index.md"
    requirements.md:
      purpose: "Comprehensive project requirements (v0.08.3.2): architecture, data flow, API contracts, deployment gates"
      location: "memory-bank/requirements.md"
    AGENTS.md:
      purpose: "Agent roles, contracts, orchestration policy, approval rules, security guardrails, and observability SLOs"
      location: "AGENTS.md"
  
  supplementary_files:
    decisions/:
      purpose: "Design decision records (ADRs)"
      examples: ["001-hybrid-storage-architecture.md", "002-deepstream-only-runtime.md", "003-privacy-first-architecture.md"]
    runbooks/:
      purpose: "Operational playbooks and procedures"
      examples: ["model-deployment.md", "nas-backup-restore.md", "promote-video-flow.md", "rollback-procedure.md"]
    templates/:
      purpose: "Templates for creating new memory notes"
      examples: ["memory_template.md"]
  
  file_handling:
    read_at_startup: ["index.md", "requirements.md", "../AGENTS.md"]
    build_complete_context: true

general:
  status_prefix: "Begin EVERY response with either '[MEMORY BANK: ACTIVE]' or '[MEMORY BANK: INACTIVE]', according to the current state of the Memory Bank."

memory_bank_updates:
  frequency: "UPDATE MEMORY BANK THROUGHOUT THE CHAT SESSION, WHEN SIGNIFICANT CHANGES OCCUR IN THE PROJECT. Use judgment to determine significance."
  
  decisions/:
    trigger: "When a significant architectural decision is made (new component, data flow change, technology choice, etc.)."
    action: "Create new ADR file using templates/memory_template.md. Number sequentially (e.g., 004-decision-name.md). Include timestamp, context, decision, rationale, consequences."
    format: "Follow ADR template structure with frontmatter metadata"
  
  requirements.md:
    trigger: "When project requirements, architecture, API contracts, or deployment gates change significantly."
    action: "Update relevant section. Add changelog entry at bottom with timestamp and summary."
    format: "[YYYY-MM-DD HH:MM:SS] - [Summary of Change]"
  
  runbooks/:
    trigger: "When new operational procedures are established or existing ones are modified."
    action: "Create new runbook or update existing using templates/memory_template.md. Include step-by-step instructions, prerequisites, validation steps."
    format: "Follow runbook template structure"
  
  index.md:
    trigger: "When new decision records or runbooks are created, or when core references change."
    action: "Add links to new resources in appropriate section. Update 'Last Updated' date at top."
    format: "Maintain existing index structure and link format"

umb: # Update Memory Bank command
  trigger: "^(Update Memory Bank|UMB)$"
  instructions:
    - "Halt Current Task: Stop current activity."
    - "Acknowledge Command: Respond with '[MEMORY BANK: UPDATING]'."
    - "Review Chat History: Analyze the complete current chat session."
  
  core_update_process: |
      1. Current Session Review: Analyze chat history for relevant decisions, context changes, progress updates, clarifications etc.
      2. Comprehensive Updates: Update relevant memory bank files based on the review, following the rules defined in 'memory_bank_updates'.
      3. Memory Bank Synchronization: Ensure consistency across updated files (e.g., if new decision added, update index.md).
      4. Changelog: Add timestamped entries to updated files documenting what changed and why.

  task_focus: "During UMB, focus ONLY on capturing information explicitly present in the *current chat session* (clarifications, decisions, progress). Do NOT summarize the entire project or perform actions outside this scope."
  cross_mode_updates: "Capture relevant information from the chat session irrespective of conceptual 'modes' mentioned, adding it to the appropriate Memory Bank files."
  
  post_umb_actions:
    - "State: Memory Bank fully synchronized based on current chat session."
    - "List files updated with brief summary of changes."
    - "State: Session context preserved for continuation."

alignment_with_agents:
  note: "These memory-bank rules complement AGENTS.md and do not override it."
  priority_stack: "Follow AGENTS.md Instruction Priority Stack (§10-14): Safety/privacy/compliance → MODEL_SPEC.md → Maintainer instructions → Defaults"
  respect_guardrails: "All memory-bank operations must respect AGENTS.md security, privacy, and approval rules."
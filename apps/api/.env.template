# Reachy Media Mover API - Environment Configuration Template
# Copy this file to .env and customize the values for your environment
# DO NOT commit .env files to version control

# ============================================================================
# Service Configuration
# ============================================================================

# Host to bind the API server (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
REACHY_API_HOST=0.0.0.0

# Port for the API server (default: 8083)
# Note: Port 8082 is used by Nginx for static files
REACHY_API_PORT=8083

# API version prefix (default: v1)
REACHY_API_VERSION=v1

# API root path for reverse proxy scenarios (default: empty)
# Example: /api/media if behind a reverse proxy
REACHY_API_ROOT_PATH=

# ============================================================================
# Storage Configuration
# ============================================================================

# Root directory for all video storage
# This directory must exist and be writable by the service user
REACHY_VIDEOS_ROOT=/mnt/videos

# Subdirectory names (relative to VIDEOS_ROOT)
REACHY_TEMP_DIR=temp
REACHY_TRAIN_DIR=train
REACHY_TEST_DIR=test
REACHY_THUMBS_DIR=thumbs
REACHY_MANIFESTS_DIR=manifests

# ============================================================================
# Database Configuration
# ============================================================================

# PostgreSQL connection URL
# Format: postgresql+asyncpg://user:password@host:port/database
REACHY_DATABASE_URL=postgresql+asyncpg://reachy_app:reachy_app@localhost:5432/reachy_local

# ============================================================================
# External Services
# ============================================================================

# Nginx (static file serving)
REACHY_NGINX_HOST=10.0.4.130
REACHY_NGINX_PORT=8082

# n8n (workflow automation)
REACHY_N8N_HOST=10.0.4.130
REACHY_N8N_PORT=5678

# Gateway (API gateway)
REACHY_GATEWAY_HOST=10.0.4.140
REACHY_GATEWAY_PORT=8000

# ============================================================================
# Feature Flags
# ============================================================================

# Enable CORS (Cross-Origin Resource Sharing)
# Set to false if API is only accessed from same origin
REACHY_ENABLE_CORS=true

# Enable legacy endpoints for backward compatibility
# Set to false after all clients have migrated to v1 endpoints
REACHY_ENABLE_LEGACY_ENDPOINTS=true

# ============================================================================
# CORS Configuration
# ============================================================================

# Comma-separated list of allowed origins for CORS
# Include all Streamlit UI hosts that will access this API
REACHY_UI_ORIGINS=http://10.0.4.140:8501,http://10.0.4.130:8501,http://localhost:8501

# ============================================================================
# Notes
# ============================================================================

# 1. After modifying this file, restart the service:
#    sudo systemctl restart fastapi-media.service
#
# 2. To validate configuration without starting the service:
#    python -c "from apps.api.app.config import load_and_validate_config; load_and_validate_config()"
#
# 3. All paths must be absolute and accessible by the service user
#
# 4. Port conflicts: Ensure REACHY_API_PORT is not used by another service
#    Check with: sudo lsof -i :8083
#
# 5. Security: Keep database credentials secure, use environment-specific .env files

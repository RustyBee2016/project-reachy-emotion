# Gateway Configuration Template for Ubuntu 2
# Copy this file to .env and adjust values as needed

# ============================================================================
# Upstream Services (Ubuntu 1)
# ============================================================================

# Media Mover API base URL (Ubuntu 1, port 8083)
GATEWAY_MEDIA_MOVER_URL=http://10.0.4.130:8083

# Nginx media server base URL (Ubuntu 1, port 8082)
GATEWAY_NGINX_MEDIA_URL=http://10.0.4.130:8082

# Database connection string (Ubuntu 1 PostgreSQL)
# Format: postgresql+asyncpg://user:password@host:port/database
GATEWAY_DATABASE_URL=postgresql+asyncpg://reachy_app:reachy_app@10.0.4.130:5432/reachy_local

# ============================================================================
# Gateway API Settings
# ============================================================================

# Host to bind to (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
GATEWAY_API_HOST=0.0.0.0

# Port for the gateway API
GATEWAY_API_PORT=8000

# Root path for the API (useful if behind a reverse proxy)
GATEWAY_API_ROOT_PATH=

# ============================================================================
# CORS Settings
# ============================================================================

# Enable CORS for web UI
GATEWAY_ENABLE_CORS=true

# Allowed origins for CORS (comma-separated)
# Include both localhost and the Ubuntu 2 IP for Streamlit UI
GATEWAY_UI_ORIGINS=http://localhost:8501,http://10.0.4.140:8501,http://localhost:3000

# ============================================================================
# Logging
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
GATEWAY_LOG_LEVEL=INFO
